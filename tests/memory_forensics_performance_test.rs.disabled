use std::time::Instant;
use tokio::time::{sleep, Duration};

use erdps_agent::memory::{
    MemoryForensicsEngine, MemoryForensicsConfig, MemoryForensicsResult
};
use erdps_agent::ml::anomaly_detector::{BehavioralFeatures, AnomalyDetectorConfig, MLAnomalyDetector};
use std::time::SystemTime;
use erdps_agent::behavioral::{BehavioralAnalysisEngine, BehavioralConfig};
use erdps_agent::behavioral::analysis_engine::RecommendedAction;

#[tokio::test]
async fn test_memory_scan_performance() {
    let config = MemoryForensicsConfig {
        enable_realtime_monitoring: false,
        scan_interval: 1,
        max_regions: 1000,
        entropy_threshold: 7.0,
        detect_process_injection: true,
        detect_shellcode: true,
        detect_heap_spray: true,
        detect_rop_chains: true,
        min_shellcode_size: 32,
        max_scan_time_ms: 500,
    };
    
    let engine = MemoryForensicsEngine::new(config).unwrap();
    
    // Test memory scan performance - should complete within 500ms
    let start = Instant::now();
    let result = engine.analyze_process_memory(std::process::id()).await;
    let duration = start.elapsed();
    
    println!("Memory scan completed in: {:?}", duration);
    assert!(duration.as_millis() < 500, "Memory scan took too long: {:?}", duration);
    assert!(result.is_ok(), "Memory scan failed: {:?}", result.err());
}

#[tokio::test]
async fn test_process_injection_detection() {
    let config = MemoryForensicsConfig {
        enable_realtime_monitoring: false,
        scan_interval: 1,
        max_regions: 1000,
        entropy_threshold: 7.0,
        detect_process_injection: true,
        detect_shellcode: false,
        detect_heap_spray: false,
        detect_rop_chains: false,
        min_shellcode_size: 32,
        max_scan_time_ms: 500,
    };
    
    let engine = MemoryForensicsEngine::new(config).unwrap();
    
    let start = Instant::now();
    let result = engine.analyze_process_memory(std::process::id()).await.unwrap();
    let duration = start.elapsed();
    
    println!("Process injection detection completed in: {:?}", duration);
    assert!(duration.as_millis() < 200, "Process injection detection too slow: {:?}", duration);
    
    // Verify detection capabilities
    // Threat indicators length is always >= 0 for Vec, so just check it exists
    println!("Found {} threat indicators", result.threat_indicators.len());
}

